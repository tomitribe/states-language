{
  "Comment": "Processes a large ledger using a distributed map",
  "QueryLanguage": "JSONata",
  "Version": "1.0",
  "TimeoutSeconds": 3600,
  "StartAt": "ProcessLedger",
  "States": {
    "ProcessLedger": {
      "Type": "Map",
      "ItemReader": {
        "Resource": "arn:aws:states:::s3:getObject",
        "ReaderConfig": {
          "InputType": "JSONL",
          "MaxItems": 1000
        },
        "Arguments": {
          "Bucket": "ledgers",
          "Key": "{% $states.input.key %}"
        }
      },
      "ItemSelector": {
        "index": "{% $states.context.Map.Item.Index %}",
        "record": "{% $states.context.Map.Item.Value %}"
      },
      "ItemBatcher": {
        "BatchInput": {
          "batchKind": "ledger"
        },
        "MaxItemsPerBatch": 50,
        "MaxInputBytesPerBatch": 262144
      },
      "ResultWriter": {
        "Resource": "arn:aws:states:::s3:putObject",
        "Arguments": {
          "Bucket": "ledgers",
          "Prefix": "results"
        }
      },
      "ItemProcessor": {
        "ProcessorConfig": {
          "Mode": "DISTRIBUTED",
          "ExecutionType": "STANDARD"
        },
        "StartAt": "HandleBatch",
        "States": {
          "HandleBatch": {
            "Type": "Task",
            "Resource": "arn:aws:lambda:us-east-1:123456789012:function:HandleBatch",
            "Credentials": {
              "RoleArn": "arn:aws:iam::123456789012:role/LedgerProcessing"
            },
            "TimeoutSeconds": 120,
            "HeartbeatSeconds": 30,
            "End": true
          }
        }
      },
      "MaxConcurrency": 100,
      "ToleratedFailureCount": 10,
      "ToleratedFailurePercentage": 5.0,
      "End": true
    }
  }
}
